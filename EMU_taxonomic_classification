## 11. Import EMU outputs into R

The following R workflow imports all `*_rel-abundance.tsv` files, combines estimated counts across samples, adds taxonomy, and creates a `phyloseq` object.

### 11.1 Load packages

```r
library(tidyverse)
library(phyloseq)
library(readxl)
```

---

### 11.2 Define paths

```r
emu_path <- "/Users/marisabelcharlocabrera/Library/CloudStorage/OneDrive-Personal/Long_Reads_16s_Saliva/EMU_outputs_2026/emu_output_lr_emu_ehomd"
metadata_path <- "/Users/marisabelcharlocabrera/Library/CloudStorage/OneDrive-Personal/Long_Reads_16s_Saliva/Barcoding_Merged_Timepoint.xlsx"
```

---

### 11.3 Read and combine EMU count tables

This version assumes that EMU was run with `--keep-counts`, so the column `estimated.counts` is present.

```r
files <- list.files(
  emu_path,
  pattern = "_rel-abundance.tsv$",
  full.names = TRUE
)

if (length(files) == 0) {
  stop("No EMU rel-abundance files were found.")
}

lista_tablas <- purrr::map(files, function(file) {

  sample_name <- basename(file) %>%
    stringr::str_remove("_rel-abundance.tsv$")

  df <- read.delim(
    file,
    header = TRUE,
    sep = "\t",
    quote = "",
    stringsAsFactors = FALSE,
    check.names = FALSE
  )

  if (!"estimated.counts" %in% colnames(df)) {
    stop(paste("The file does not contain estimated.counts. Re-run EMU with --keep-counts:", file))
  }

  df %>%
    dplyr::select(
      tax_id,
      dplyr::any_of(c("Domain", "Phylum", "Class", "Order", "Family", "Genus", "Species", "Subspecies")),
      estimated_counts = estimated.counts
    ) %>%
    dplyr::rename(!!sample_name := estimated_counts)
})

conteo_tabla <- purrr::reduce(
  lista_tablas,
  dplyr::full_join,
  by = c("tax_id", "Domain", "Phylum", "Class", "Order", "Family", "Genus", "Species", "Subspecies")
)

conteo_tabla <- conteo_tabla %>%
  dplyr::mutate(across(where(is.numeric), ~ tidyr::replace_na(.x, 0)))

output_file <- file.path(emu_path, "EMU_combined_counts_taxonomy.csv")
readr::write_csv(conteo_tabla, output_file)
```

---

### 11.4 Read and clean metadata

```r
sample_meta <- readxl::read_excel(metadata_path)

sample_meta <- sample_meta %>%
  mutate(
    Barcode = stringr::str_remove(Barcode, "_duplicado"),
    Barcode = stringr::str_replace(Barcode, "barcode(\\d)$", "barcode0\\1")
  )
```

If your EMU output names include length-filter suffixes, remove them from the count table column names:

```r
colnames(conteo_tabla) <- stringr::str_remove(
  colnames(conteo_tabla),
  "_1300-1700bp"
)
```

---

### 11.5 Create the OTU/count matrix

Identify sample columns as all columns that are not taxonomy columns.

```r
taxonomy_cols <- c(
  "tax_id", "Domain", "Phylum", "Class", "Order",
  "Family", "Genus", "Species", "Subspecies"
)

sample_cols <- setdiff(colnames(conteo_tabla), taxonomy_cols)

otu_mat <- conteo_tabla %>%
  dplyr::select(dplyr::all_of(sample_cols)) %>%
  as.matrix()

otu_mat <- round(otu_mat)
rownames(otu_mat) <- conteo_tabla$tax_id

otu_mat[is.na(otu_mat)] <- 0
```

Check dimensions:

```r
dim(otu_mat)
otu_mat[1:5, 1:min(5, ncol(otu_mat))]
```

---

### 11.6 Create the taxonomy matrix

```r
tax_cols <- c("Domain", "Phylum", "Class", "Order", "Family", "Genus", "Species")

tax_mat <- conteo_tabla %>%
  dplyr::select(dplyr::all_of(tax_cols)) %>%
  as.matrix()

rownames(tax_mat) <- conteo_tabla$tax_id
```

---

### 11.7 Match metadata to the OTU matrix

```r
sample_meta_df <- sample_meta %>%
  filter(Barcode %in% colnames(otu_mat)) %>%
  arrange(match(Barcode, colnames(otu_mat))) %>%
  as.data.frame()

rownames(sample_meta_df) <- sample_meta_df$Barcode
```

Check that sample order matches exactly:

```r
stopifnot(all(rownames(sample_meta_df) == colnames(otu_mat)))
```

---

### 11.8 Create the phyloseq object

```r
otu_tab <- phyloseq::otu_table(otu_mat, taxa_are_rows = TRUE)
tax_tab <- phyloseq::tax_table(tax_mat)
meta_tab <- phyloseq::sample_data(sample_meta_df)

ps <- phyloseq::phyloseq(otu_tab, tax_tab, meta_tab)
ps
```

Expected structure:

```text
phyloseq-class experiment-level object
otu_table()   OTU Table:         [ taxa x samples ]
sample_data() Sample Data:       [ samples x variables ]
tax_table()   Taxonomy Table:    [ taxa x ranks ]
```

Save the object:

```r
saveRDS(ps, file.path(emu_path, "phyloseq_EMU_eHOMD.rds"))
```
